# ==========================================
# SMART INVESTOR PRO MVP – Environment Config
# ==========================================

# 🔐 AUTH & APP
SECRET_KEY=change-me-32chars-minimum
USE_MOCK_DATA=true  # false = yfinance live, true = mock fallback

# 🤖 LLM PROVIDER (OpenAI-kompatibel)
# Option A: DeepSeek (empfohlen für Kosten/Performance)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# Option B: Gemini (Alternative/Parallel)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# ⚙️ ENGINE
DEFAULT_PROVIDER=deepseek  # deepseek | gemini
PARALLEL_ANALYSIS=false    # true = alle Provider parallel + Consensus Scoring
LLM_COST_BUDGET=0.50

# 🗄️ DATABASE (Neon PostgreSQL – Vercel)
DATABASE_URL=postgresql://user:pass@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# 📦 REDIS CACHE (optional)
# REDIS_URL=redis://localhost:6379/0
# REDIS_TTL_MARKET=86400
# REDIS_TTL_LLM=3600
# CACHE_ENABLED=true
MAX_REQUESTS_PER_MINUTE=20

# 📊 DATA PROVIDER (automatisch: yfinance → SEC EDGAR → Mock)
# Keine Keys nötig. FreeDataProvider läuft out-of-the-box.
