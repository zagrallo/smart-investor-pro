# ==========================================
# SMART INVESTOR PRO MVP – Environment Config
# ==========================================

# 🔐 AUTH & APP
SECRET_KEY=change-me-32chars-minimum
USE_MOCK_DATA=true  # false = yfinance live, true = mock fallback

# 🤖 LLM PROVIDER (OpenAI-kompatibel)
# Option A: DeepSeek (empfohlen für Kosten/Performance)
LLM_API_KEY=sk-your-deepseek-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Option B: OpenAI ChatGPT (einfach BASE_URL & KEY tauschen)
# LLM_API_KEY=sk-proj-your-openai-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Legacy: DEEPSEEK_* wird automatisch als Fallback genutzt
# DEEPSEEK_API_KEY=sk-your-key

# ⚙️ COST & LIMITS
LLM_COST_BUDGET=0.50
MAX_REQUESTS_PER_MINUTE=5

# 📊 DATA PROVIDER (automatisch: yfinance → SEC EDGAR → Mock)
# Keine Keys nötig. FreeDataProvider läuft out-of-the-box.
